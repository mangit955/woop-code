{
  "description": "Agent calls a tool and continues",
  "input": {
    "userPrompt": "Read the README file",
    "repoContext": "Files: README.md, package.json"
  },
  "providerResponse": {
    "iterations": [
      {
        "events": [
          {
            "type": "tool_call",
            "id": "call-123",
            "name": "read_file",
            "arguments": { "path": "README.md" }
          },
          { "type": "done" }
        ]
      },
      {
        "events": [
          { "type": "text", "content": "The README contains project documentation." },
          { "type": "done" }
        ]
      }
    ]
  },
  "toolResponse": {
    "read_file": "# Project\n\nThis is the README content."
  },
  "expectedConversation": [
    {
      "role": "user",
      "content": "Read the README file"
    },
    {
      "role": "assistant_tool_call",
      "toolName": "read_file",
      "toolCallId": "call-123",
      "arguments": { "path": "README.md" }
    },
    {
      "role": "tool",
      "toolName": "read_file",
      "toolCallId": "call-123",
      "content": "# Project\n\nThis is the README content."
    },
    {
      "role": "assistant",
      "content": "The README contains project documentation."
    }
  ],
  "expectedResult": "The README contains project documentation.",
  "expectedCallbacks": {
    "onText": 1,
    "onDone": 1,
    "onToolStart": 1,
    "onToolFinish": 1,
    "onError": 0,
    "onCancel": 0
  }
}
